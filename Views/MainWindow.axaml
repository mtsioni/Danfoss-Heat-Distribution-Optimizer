<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/avalonia"
        xmlns:vm="clr-namespace:Danfoss_Heat_Distribution_Optimizer.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="Danfoss_Heat_Distribution_Optimizer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Heat Optimization Tool"
        Icon="avares://Danfoss_Heat_Distribution_Optimizer/Assets/Images/AppIcon.png"
        Background="#EED9B9"
        WindowState="Maximized">

    <!-- theme color definitions - swap these to change the base app color scheme -->
    <!-- the x:Key names are referenced with DynamicResource throughout the file -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                
                <!-- light theme colors -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="RightPanelBg">#F2E6D8</SolidColorBrush>
                    <SolidColorBrush x:Key="ChartAreaBg">#E8DACB</SolidColorBrush>
                    <SolidColorBrush x:Key="MainText">#5E0006</SolidColorBrush>
                </ResourceDictionary>
                
                <!-- dark theme colors -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="RightPanelBg">#1E1E1E</SolidColorBrush>
                    <SolidColorBrush x:Key="ChartAreaBg">#333333</SolidColorBrush>
                    <SolidColorBrush x:Key="MainText">#efebe5</SolidColorBrush>
                </ResourceDictionary>
                
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="RadioButton.Segmented">
            <Setter Property="Background" Value="#efebe5"/>
            <Setter Property="Foreground" Value="#4A0404"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="RadioButton.SegmentedLeft">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="20,0,0,20" Padding="5,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="✓" IsVisible="{TemplateBinding IsChecked}" Foreground="{TemplateBinding Foreground}" FontWeight="Bold"/>
                            <ContentPresenter Content="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.SegmentedRight">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="0,20,20,0" Padding="5,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="✓" IsVisible="{TemplateBinding IsChecked}" Foreground="{TemplateBinding Foreground}" FontWeight="Bold"/>
                            <ContentPresenter Content="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.Segmented:checked">
            <Setter Property="Background" Value="#4A0404"/>
            <Setter Property="Foreground" Value="#efebe5"/>
        </Style>

        <Style Selector="Button.LegendButton:pressed">
            <Setter Property="RenderTransform" Value="none" />
        </Style>
    </Window.Styles>

    <!-- two column layout: 300px sidebar + rest of window -->
    <Grid ColumnDefinitions="300, *">

        <!-- left sidebar -->
        <!-- Grid.Column="0" puts this into the first 300px column -->
        <!-- RowDefinitions="Auto, *, Auto" means top/bottom rows are content-sized, middle expands -->
        <Border Grid.Column="0" Background="#d01d29" Padding="20,40,20,20">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <!-- top section with controls -->
                <StackPanel Grid.Row="0" Spacing="25">
                    <TextBlock Text="Control Panel" FontSize="35" FontWeight="Bold" Foreground="#efebe5" HorizontalAlignment="Center"/>

                    <!-- scenario selection -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="SCENARIOS" FontSize="14" FontWeight="SemiBold" Foreground="#efebe5"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <RadioButton Grid.Column="0" Classes="Segmented SegmentedLeft" Content="Heat" 
                                        GroupName="ScenariosGroup" IsChecked="{Binding IsHeatScenarioSelected}"/>
                            <RadioButton Grid.Column="1" Classes="Segmented SegmentedRight" Content="Heat &amp; Electricity" 
                                        GroupName="ScenariosGroup" IsChecked="{Binding IsHeatAndElecScenarioSelected}"/>
                        </Grid>
                    </StackPanel>

                    <!-- period selection -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="PERIOD" FontSize="14" FontWeight="SemiBold" Foreground="#efebe5"/>
                        <Grid ColumnDefinitions="*,*">
                            <RadioButton Grid.Column="0" Classes="Segmented SegmentedLeft" Content="Winter" 
                                        GroupName="PeriodGroup" IsChecked="{Binding IsWinterSelected}"/>
                            <RadioButton Grid.Column="1" Classes="Segmented SegmentedRight" Content="Summer" 
                                        GroupName="PeriodGroup" IsChecked="{Binding IsSummerSelected}"/>
                        </Grid>
                    </StackPanel>

                    <!-- unit control section -->
                    <TextBlock Text="Unit Control" FontSize="35" FontWeight="Bold" Foreground="#efebe5" HorizontalAlignment="Center" Margin="0,20,0,0"/>

                    <StackPanel Spacing="15">
                        <TextBlock Text="MAINTENANCE PLANNING" FontSize="20" FontWeight="Bold" Foreground="#efebe5" HorizontalAlignment="Center"/>
                        
                        <!-- slider for maintenance hours -->
                        <Slider x:Name="Hours" Minimum="30" Maximum="60" Foreground="#efebe5" IsSnapToTickEnabled="True" TickFrequency="1" Value="{Binding MaintenanceHours}">
                            <Slider.Resources>
                                <SolidColorBrush x:Key="SliderTrackFill">#4A0404</SolidColorBrush>
                                <SolidColorBrush x:Key="SliderTrackValueFill">#efebe5</SolidColorBrush>
                                <SolidColorBrush x:Key="SliderThumbBackground">#efebe5</SolidColorBrush>
                            </Slider.Resources>
                        </Slider>
                        
                        <!-- static display of selected hours -->
                        <TextBlock Foreground="#efebe5" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center">
                            <Run Text="{Binding #Hours.Value}"/>
                            <Run Text="hours"/>
                        </TextBlock>
                        
                        <!-- dropdown for selecting unit -->
                        <ComboBox PlaceholderText="Select a production unit" 
                                PlaceholderForeground="#efebe5"
                                HorizontalAlignment="Stretch" 
                                Foreground="#efebe5"
                                Background="#4A0404"
                                BorderBrush="#efebe5"
                                BorderThickness="1"
                                Margin="0,15,0,0" 
                                CornerRadius="20"
                                Padding="15,10"
                                ItemsSource="{Binding Units}"
                                SelectedItem="{Binding SelectedUnit}">
                            <ComboBox.Resources>
                                <SolidColorBrush x:Key="ComboBoxDropDownBackground">#4A0404</SolidColorBrush>
                                <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush">#efebe5</SolidColorBrush>
                                <SolidColorBrush x:Key="ComboBoxPlaceholderTextForeground">#efebe5</SolidColorBrush>
                            </ComboBox.Resources>
                            <ComboBox.Styles>
                                <Style Selector="ComboBoxItem">
                                    <Setter Property="Foreground" Value="#efebe5"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Margin" Value="2,1"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Transitions">
                                        <Transitions>
                                            <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                        </Transitions>
                                    </Setter>
                                </Style>
                                <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#d01d29"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                                <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#5E0006"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </ComboBox.Styles>
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:UnitViewModel">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <!-- bottom section: theme toggle -->
                <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,20,0,0">
                    <TextBlock Grid.Column="0" Text="LIGHT/DARK THEME" FontSize="18" Foreground="#efebe5" VerticalAlignment="Center"/>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDarkTheme}" OffContent="" OnContent=""/>
                </Grid>
            </Grid>
        </Border>

        <!-- right side content area -->
        <!-- DynamicResource picks up the correct color from the theme dict above -->
        <Border Grid.Column="1" Background="{DynamicResource RightPanelBg}" Padding="20">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <!-- header with logo -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="HEAT PRODUCTION OPTIMIZATION TOOL V1.0" FontSize="18" Foreground="{DynamicResource MainText}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Heatington ~ 1600" Foreground="{DynamicResource MainText}" FontFamily="Segoe UI"/>
                    </StackPanel>
                    
                    <!-- brand label -->
                    <Image x:Name="Logo" Grid.Column="1" Width="100"/>
                </Grid>

                <!-- chart area -->
                <Border Grid.Row="1" Background="{DynamicResource ChartAreaBg}" Margin="0,15" BorderBrush="{DynamicResource MainText}" BorderThickness="1" CornerRadius="15">
                    <Grid RowDefinitions="*, Auto">
                        
                        <!-- the oxyplot chart control -->


                        <oxy:PlotView Grid.Row="0" Model="{Binding Visualizer.CurrentPlotModel}" Background="Transparent"/>

                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="40,15,40,25">
                            <!-- Metric Selection Toggles -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="30" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <CheckBox Content="Heat Demand" IsChecked="{Binding ShowHeatDemand}" IsEnabled="{Binding IsEnergyEnabled}" Foreground="{DynamicResource MainText}"/>
                                <CheckBox Content="Heat Production" IsChecked="{Binding ShowHeatProduction}" IsEnabled="{Binding IsEnergyEnabled}" Foreground="{DynamicResource MainText}"/>
                                <CheckBox Content="Electricity" IsChecked="{Binding ShowElectricity}" IsEnabled="{Binding IsEnergyEnabled}" Foreground="{DynamicResource MainText}"/>
                                <CheckBox Content="Electricity Price" IsChecked="{Binding ShowElectricityPrice}" IsEnabled="{Binding IsFinanceEnabled}" Foreground="{DynamicResource MainText}"/>
                                <CheckBox Content="CO2 Emissions" IsChecked="{Binding ShowCo2Emissions}" IsEnabled="{Binding IsCo2Enabled}" Foreground="{DynamicResource MainText}"/>
                                <CheckBox Content="Fuel Consumption" IsChecked="{Binding ShowFuelConsumption}" IsEnabled="{Binding IsFuelEnabled}" Foreground="{DynamicResource MainText}"/>
                                <CheckBox Content="Production Costs" IsChecked="{Binding ShowProductionCosts}" IsEnabled="{Binding IsFinanceEnabled}" Foreground="{DynamicResource MainText}"/>
                            </StackPanel>

                            <!-- Legend Control (Bottom Right) -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Classes="LegendButton"
                                        Background="Transparent" 
                                        BorderBrush="{DynamicResource MainText}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource MainText}"
                                        CornerRadius="15"
                                        Padding="12,6"
                                        Command="{Binding Visualizer.ToggleLegend}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Legend" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="▲" VerticalAlignment="Center" IsVisible="{Binding Visualizer.IsLegendExpanded}"/>
                                        <TextBlock Text="▼" VerticalAlignment="Center" IsVisible="{Binding !Visualizer.IsLegendExpanded}"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Legend Popup -->
                                <Popup IsOpen="{Binding Visualizer.IsLegendExpanded, Mode=TwoWay}" 
                                       Placement="Top" 
                                       PlacementGravity="TopRight"
                                       IsLightDismissEnabled="True">
                                    <Border Background="{DynamicResource ChartAreaBg}" 
                                            BorderBrush="{DynamicResource MainText}" 
                                            BorderThickness="1" 
                                            CornerRadius="10"
                                            Padding="15"
                                            Margin="0,0,0,10"
                                            BoxShadow="0 4 10 0 #40000000">
                                        <StackPanel>
                                            <TextBlock Text="PRODUCTION UNITS" FontWeight="Bold" Foreground="{DynamicResource MainText}" Margin="0,0,0,10" FontSize="12"/>
                                            <ItemsControl ItemsSource="{Binding Visualizer.ActiveLegendItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                            <Rectangle Width="16" Height="4" Fill="{Binding Brush}" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource MainText}" VerticalAlignment="Center" FontSize="12"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </Grid>

                    </Grid>
                </Border>

                <!-- unit cards section with pagination arrows -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" Height="230" Margin="0,5,0,0">

                    <!-- prev arrow -->
                    <Button Grid.Column="0"
                            Content="◀"
                            FontSize="22"
                            Background="Transparent"
                            Foreground="{DynamicResource MainText}"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding CanGoPrev}"
                            Click="OnPrevPageClicked"/>

                    <!-- 3 unit cards -->
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding VisibleUnits}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:UnitViewModel">
                                <!-- outer card — rounded corners, clips the image to round edges -->
                                <Border CornerRadius="15" Margin="5" ClipToBounds="True">
                                    <Grid ColumnDefinitions="*, *">

                                        <!-- left half: machine photo fills the space -->
                                        <Image Grid.Column="0"
                                               Source="{Binding Image}"
                                               Stretch="UniformToFill"/>

                                        <!-- right half: red panel with stats -->
                                        <Border Grid.Column="1" Background="#d01d29" Padding="10,8">
                                            <StackPanel Spacing="0" VerticalAlignment="Center">

                                                <!-- big unit name -->
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="Segoe UI" FontSize="23" FontWeight="Bold"
                                                           Foreground="White" Margin="0,0,0,6"/>

                                                <TextBlock Text="Max Heat"
                                                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding MaxHeatText}"
                                                           FontFamily="Segoe UI" FontSize="14"
                                                           Foreground="White" Margin="0,0,0,4"/>

                                                <TextBlock Text="Max Electricity"
                                                           IsVisible="{Binding HasElectricity}"
                                                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding MaxElectricityText}"
                                                           IsVisible="{Binding HasElectricity}"
                                                           FontFamily="Segoe UI" FontSize="14"
                                                           Foreground="White" Margin="0,0,0,4"/>

                                                <TextBlock Text="Production Cost"
                                                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding ProductionCostText}"
                                                           FontFamily="Segoe UI" FontSize="14"
                                                           Foreground="White" Margin="0,0,0,4"/>

                                                <TextBlock Text="CO2 Emissions"
                                                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding Co2Text}"
                                                           FontFamily="Segoe UI" FontSize="14"
                                                           Foreground="White" Margin="0,0,0,4"/>

                                                <TextBlock Text="{Binding FuelConsumptionLabel}"
                                                           IsVisible="{Binding HasFuelConsumption}"
                                                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding FuelConsumptionText}"
                                                           IsVisible="{Binding HasFuelConsumption}"
                                                           FontFamily="Segoe UI" FontSize="14"
                                                           Foreground="White"/>

                                            </StackPanel>
                                        </Border>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- next arrow -->
                    <Button Grid.Column="2"
                            Content="▶"
                            FontSize="22"
                            Background="Transparent"
                            Foreground="{DynamicResource MainText}"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding CanGoNext}"
                            Click="OnNextPageClicked"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>